# shellcheck disable=SC2148,SC1091
if [ ! -f .venv/bin/activate ]; then
    if has uv; then
        uv sync --all-groups
    else
        echo "Error: uv is missing. Please install it from https://docs.astral.sh/uv/"
    fi
fi

if [ -f .venv/bin/activate ]; then
    source .venv/bin/activate
fi

PATH_add scripts

export PYOCD_PROJECT_DIR=$PWD

# Zephyr + Zephyr SDK
# compatibility matrix: https://github.com/zephyrproject-rtos/sdk-ng/wiki/Zephyr-Version-Compatibility#zephyr-sdk-version-compatibility-matrix
if compgen -G "/opt/zephyr-sdk-*/" >/dev/null; then 
    export ZEPHYR_SDK_INSTALL_DIR=/opt/
else
    echo -e "\e[31mError: Zephyr SDK is missing! Desired Directory: /opt/zephyr-sdk-<version>/ \e[0m"
    echo -e "See https://docs.zephyrproject.org/latest/develop/toolchains/zephyr_sdk.html#installation-bundle-and-variables for installation instructions."
fi
export ZEPHYR_TOOLCHAIN_VARIANT=zephyr

dotenv_if_exists
