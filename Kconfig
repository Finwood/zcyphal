menuconfig ZCYPHAL
	bool "Cyphal v1.1 over CAN (zcyphal)"
	select CAN
	select HWINFO
	select LOG
	help
	  Enable the zcyphal module integrating Cyphal v1.1 with Zephyr CAN.

if ZCYPHAL

module = ZCYPHAL
module-str = zcyphal
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"

config ZCYPHAL_HEAP_SIZE
	int "Cy heap size (bytes)"
	default 32768

config ZCYPHAL_NODE_HOME
	string "Default node home name"
	default "zcyphal"

config ZCYPHAL_CAN_FD
	bool "Enable CAN FD support"
	default n

config ZCYPHAL_CAN_LOOPBACK
	bool "Enable CAN controller loopback mode"
	default n
	help
	  Set CAN_MODE_LOOPBACK on the bound controller. Use with Zephyr
	  loopback CAN drivers (e.g. native_sim) for local TX/RX testing.

config ZCYPHAL_AUTO_INIT
	bool "Initialize zcyphal automatically at boot"
	default n

config ZCYPHAL_TX_QUEUE_SIZE
	int "Cyphal TX queue capacity"
	default 128

config ZCYPHAL_RX_QUEUE_SIZE
	int "Zephyr CAN RX queue depth"
	default 32

config ZCYPHAL_FILTER_COUNT
	int "Maximum concurrent CAN RX filters"
	default 8

config ZCYPHAL_THREAD_STACK_SIZE
	int "Spin thread stack size (bytes)"
	default 4096

config ZCYPHAL_THREAD_PRIORITY
	int "Spin thread priority"
	default 5

config ZCYPHAL_SPIN_SLICE_US
	int "Spin slice duration (microseconds)"
	default 10000

config ZCYPHAL_NAMESPACE
	string "Default Cyphal namespace"
	default ""

config ZCYPHAL_REMAP
	string "Default Cyphal name remap rules"
	default ""

config ZCYPHAL_PRNG_SEED
	hex "Fallback PRNG seed when hwinfo is unavailable"
	default 0x5a63797068616c00

config ZCYPHAL_TRACE
	bool "Enable cy internal trace logging"
	default n

endif
